# ERAMS Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.
#
# These values are injected at Flutter build time via --dart-define:
#   flutter run -d chrome \
#     --dart-define=SUPABASE_URL=$SUPABASE_URL \
#     --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
#
# In Dart, read them with: String.fromEnvironment('SUPABASE_URL')

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# Supabase CLI (local dev only — used by `supabase db push` / `migration list`,
# never read by the Flutter app). Get/reset at:
# Supabase Dashboard -> Project Settings -> Database -> Connection string / Reset password
SUPABASE_DB_PASSWORD=your-db-password-here
